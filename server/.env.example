# Server Port
PORT=5000

# Environment (development/production)
NODE_ENV=production

# Supabase Configurations
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# CORS / Frontend URL
# Set this to your deployed frontend URL (e.g., https://rescuebite.onrender.com)
# Use '*' to allow all origins (Note: credentials will be disabled if '*' is used)
FRONTEND_URL=*

# Email Configurations (if used)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Authentication
# Add other keys if needed
JWT_SECRET=your_jwt_secret_if_not_using_supabase_auth_directly
